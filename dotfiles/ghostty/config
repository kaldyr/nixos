# Fonts
font-family = "Maple Mono NF"
font-feature = calt
font-feature = cv02
font-feature = cv03
font-feature = cv05
font-feature = cv07
font-feature = cv31
font-feature = cv38
font-feature = cv40
font-feature = cv62
font-feature = ss03
font-feature = ss07
font-feature = ss08
font-feature = ss11
font-feature = zero
font-size = 10.6
font-thicken = true

# Theme
gtk-custom-css = frappe.css
gtk-tabs-location = bottom
gtk-wide-tabs = false
theme = Catppuccin Frappe

# Integrations
shell-integration = fish
window-decoration = false
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0

# Keybindings
keybind = alt+\=reload_config
keybind = alt+minus=decrease_font_size:1
keybind = alt+equal=increase_font_size:1
keybind = alt+zero=reset_font_size

# Scrollback
keybind = alt+u=scroll_page_up
keybind = alt+d=scroll_page_down
keybind = alt+e=write_scrollback_file:open

# Tabs
keybind = alt+t=new_tab
keybind = alt+.=next_tab
keybind = alt+,=previous_tab
keybind = alt+shift+t=prompt_tab_title
keybind = alt+shift+.=move_tab:1
keybind = alt+shift+,=move_tab:-1

# Windows
keybind = alt+f=toggle_split_zoom
keybind = alt+n=new_split:down
keybind = alt+v=new_split:right
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up
keybind = alt+l=goto_split:right
keybind = alt+shift+h=goto_split:left
keybind = alt+shift+j=goto_split:down
keybind = alt+shift+k=goto_split:up
keybind = alt+shift+l=goto_split:right
keybind = alt+left=resize_split:left,1
keybind = alt+down=resize_split:down,1
keybind = alt+up=resize_split:up,1
keybind = alt+right=resize_split:right,1
keybind = alt+shift+left=resize_split:left,20
keybind = alt+shift+down=resize_split:down,20
keybind = alt+shift+up=resize_split:up,20
keybind = alt+shift+right=resize_split:right,20
keybind = alt+backquote=toggle_quick_terminal
